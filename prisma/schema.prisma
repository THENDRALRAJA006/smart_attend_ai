generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model alembic_version {
  version_num String @id(map: "alembic_version_pkc") @db.VarChar(32)
}

model attendance {
  id                  Int       @id @default(autoincrement())
  student_id          Int
  session_id          Int
  status              String    @default("present") @db.VarChar(20)
  verification_method String    @db.VarChar(50)
  similarity_score    Float?
  timestamp           DateTime? @default(now()) @db.Timestamp(6)
  sessions            sessions  @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students            students  @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([student_id, session_id], map: "uq_student_session")
}

model ble_beacons {
  id             Int        @id @default(autoincrement())
  classroom_id   Int
  uuid           String     @unique @db.VarChar(100)
  device_name    String?    @db.VarChar(100)
  rssi_threshold Int        @default(-70)
  is_active      Boolean    @default(true)
  classrooms     classrooms @relation(fields: [classroom_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model classrooms {
  id          Int           @id @default(autoincrement())
  room_name   String        @unique @db.VarChar(50)
  building    String?       @db.VarChar(50)
  capacity    Int?
  ble_beacons ble_beacons[]
}

model faculty {
  id            Int        @id @default(autoincrement())
  name          String     @db.VarChar(100)
  employee_id   String     @unique @db.VarChar(50)
  email         String     @unique @db.VarChar(100)
  password_hash String     @db.VarChar(255)
  sessions      sessions[]
}

model liveness_tokens {
  id         Int       @id @default(autoincrement())
  student_id Int
  token      String    @unique @db.VarChar(255)
  challenge  String    @db.VarChar(50)
  is_used    Boolean   @default(false)
  expires_at DateTime  @db.Timestamp(6)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  students   students  @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model sessions {
  id           Int          @id @default(autoincrement())
  faculty_id   Int
  subject_name String       @db.VarChar(100)
  classroom    String       @db.VarChar(50)
  session_code String       @unique @db.VarChar(50)
  start_time   DateTime     @db.Timestamp(6)
  end_time     DateTime     @db.Timestamp(6)
  attendance   attendance[]
  faculty      faculty      @relation(fields: [faculty_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model students {
  id              Int               @id @default(autoincrement())
  full_name       String            @db.VarChar(100)
  roll_number     String            @unique @db.VarChar(50)
  department      String?           @db.VarChar(100)
  year            Int?
  section         String?           @db.VarChar(20)
  email           String            @unique @db.VarChar(100)
  password_hash   String            @db.VarChar(255)
  face_embeddings Json?             @db.Json
  created_at      DateTime?         @default(now()) @db.Timestamp(6)
  attendance      attendance[]
  liveness_tokens liveness_tokens[]
}
