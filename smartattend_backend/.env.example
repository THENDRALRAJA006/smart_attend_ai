# Supabase PostgreSQL connection configurations
DATABASE_URL=postgresql://postgres:your-database-password-goes-here@db.supabase.co:5432/postgres

# Fallback separate connection settings if DATABASE_URL is not used
DB_HOST=db.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-database-password-goes-here

# Supabase Server SDK Configurations
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json

# JWT Configurations
JWT_SECRET=your-cryptographically-random-key-min-32-chars
JWT_ALGORITHM=HS256

# Environment settings
ENVIRONMENT=production
