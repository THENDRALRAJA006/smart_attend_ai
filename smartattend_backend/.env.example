# ══════════════════════════════════════════════════════
# SmartAttend AI — Environment Variables
# Copy to .env and fill in your actual values
# ══════════════════════════════════════════════════════

# ── AWS RDS MySQL ──────────────────────────────────────
# Full connection string (preferred)
DATABASE_URL=mysql+pymysql://smartattend_user:your-rds-password@your-rds-endpoint.rds.amazonaws.com:3306/smartattend?charset=utf8mb4

# Or set individually (used if DATABASE_URL is not set)
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_NAME=smartattend
DB_USER=smartattend_user
DB_PASSWORD=your-rds-password

# ── JWT Security ────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-cryptographically-random-secret-key-minimum-32-characters
JWT_ALGORITHM=HS256

# ── InsightFace / ArcFace ──────────────────────────────
ARCFACE_MODEL_NAME=buffalo_l

# ── Environment ────────────────────────────────────────
ENVIRONMENT=production

# ── Face Registration Tuning ────────────────────────────
MAX_FACE_EMBEDDINGS=50
MIN_FRAMES_FOR_REGISTRATION=20
SHARPNESS_THRESHOLD=100.0
DETECTION_CONFIDENCE_THRESHOLD=0.95
DEDUP_SIMILARITY_THRESHOLD=0.98

# ── Liveness ────────────────────────────────────────────
LIVENESS_TOKEN_EXPIRY_MINUTES=3

# ── Attendance Thresholds ────────────────────────────────
SIMILARITY_THRESHOLD_PRESENT=0.75
SIMILARITY_THRESHOLD_REVIEW=0.65

# ── Rate Limiting ────────────────────────────────────────
MAX_VERIFICATION_ATTEMPTS=5
